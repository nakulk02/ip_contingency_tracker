# Database (required)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ip_contingency?schema=public"

# NextAuth (required)
# Generate NEXTAUTH_SECRET with: openssl rand -base64 32
NEXTAUTH_SECRET="generate-a-secret-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Redis (optional — falls back to in-memory rate limiting if unset)
REDIS_URL="redis://localhost:6379"

# Logging (optional — defaults to "debug" in development, "info" in production)
# One of: fatal, error, warn, info, debug, trace
LOG_LEVEL="debug"

# Intelligence layer (required for /api/v1/intelligence/* routes)
# This is consumed by the ip-contingency-mcp package, not this app directly,
# but must be set in this app's environment since the MCP tools run in-process.
ANTHROPIC_API_KEY="sk-ant-..."
